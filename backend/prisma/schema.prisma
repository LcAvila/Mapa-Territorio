generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int                   @id @default(autoincrement())
  username          String                @unique
  password          String
  role              String                @default("user")
  tipo              String                @default("Usuário")
  full_name         String?
  cpf_cnpj          String?
  telefone          String?
  cep               String?
  logradouro        String?
  numero            String?
  complemento       String?
  bairro_end        String?
  cidade            String?
  estado_end        String?
  photo             String?
  created_at        DateTime              @default(now())
  default_workspace String?               @default("admin")
  inactivity_limit  Int?                  @default(30)
  notif_email       Boolean               @default(true)
  notif_sms         Boolean               @default(false)
  notif_push        Boolean               @default(true)
  last_active       DateTime              @default(now())
  token_version     Int                   @default(0)
  birth_date        DateTime?
  code              String?               @unique
  colorIndex        Int                   @default(0)
  comissao          Float?
  isVago            Int                   @default(0)
  cargo             String?
  company_name      String?
  groupId           Int?
  area_atuacao      String?
  base_logistica    String?
  email             String?
  supabase_id       String?               @unique
  userTypeId        Int?
  bairros           Bairro[]              @relation("UserBairros")
  blocosViagem      BlocosViagem[]
  clientes          Cliente[]             @relation("UserClientes")
  visitasLogistica  DistanciasLogistica[]
  FeedComment       FeedComment[]
  FeedPost          FeedPost[]
  FeedReaction      FeedReaction[]
  historicosVisitas HistoricoVisitas[]
  interests         InterestRequest[]     @relation("UserInterests")
  planejamentos     PlanejamentoVisitas[]
  territories       Territory[]           @relation("UserTerritories")
  activities        UserActivity[]
  permissions       UserPermission[]
  group             Group?                @relation(fields: [groupId], references: [id])
  userType          UserType?             @relation(fields: [userTypeId], references: [id])
  managedUsers      User[]                @relation("UserManagement")
  managedBy         User[]                @relation("UserManagement")

  // Route Planning relations
  routeCycles       RouteCycle[]          @relation("SupervisorCycles")
  createdCycles     RouteCycle[]          @relation("CreatorCycles")
  routeSequences    RouteSequence[]
  auditLogs         RouteAuditLog[]
  exports           RouteExport[]

  @@map("users")
}

model RouteCycle {
  id                 Int                   @id @default(autoincrement())
  name               String
  start_date         DateTime
  end_date           DateTime
  status             String                @default("rascunho") // rascunho, calculando, pronto_revisao, publicado, em_execucao, finalizado, cancelado
  supervisor_user_id Int
  created_by         Int
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt

  supervisor         User                  @relation("SupervisorCycles", fields: [supervisor_user_id], references: [id])
  creator            User                  @relation("CreatorCycles", fields: [created_by], references: [id])
  weeks              RouteCycleWeek[]
  clientSnapshots    RouteClientSnapshot[]
  assignments        RouteAssignment[]
  sequences          RouteSequence[]
  clusters           RouteCluster[]
  blocks             RouteBlock[]
  exports            RouteExport[]

  @@map("route_cycles")
}

model RouteCycleWeek {
  id             Int               @id @default(autoincrement())
  route_cycle_id Int
  week_number    Int               // 1 a 4
  start_date     DateTime
  end_date       DateTime
  status         String            @default("pendente")
  
  cycle          RouteCycle        @relation(fields: [route_cycle_id], references: [id], onDelete: Cascade)
  assignments    RouteAssignment[]
  sequences      RouteSequence[]
  clusters       RouteCluster[]
  blocks         RouteBlock[]

  @@map("route_cycle_weeks")
}

model RouteClientSnapshot {
  id                   Int               @id @default(autoincrement())
  route_cycle_id       Int
  client_id            Int
  owner_user_id        Int
  supervisor_user_id   Int
  client_name          String
  trade_name           String?
  cnpj                 String?
  address              String?
  city                 String?
  state                String?
  zip_code             String?
  classification       String?           // Estratégico, Forte, Médio, Pontual
  latitude             Float?
  longitude            Float?
  distance_base_km     Float?
  source_base          String?
  source_logistic_type String?

  cycle                RouteCycle        @relation(fields: [route_cycle_id], references: [id], onDelete: Cascade)
  assignments          RouteAssignment[]
  sequenceItems        RouteSequenceItem[]

  @@map("route_clients_snapshot")
}

model RouteAssignment {
  id                 Int                 @id @default(autoincrement())
  route_cycle_id     Int
  week_id            Int
  client_snapshot_id Int
  assigned_by        Int
  assigned_at        DateTime            @default(now())
  assignment_mode    String              @default("automatic") // automatic, manual
  notes              String?

  cycle              RouteCycle          @relation(fields: [route_cycle_id], references: [id], onDelete: Cascade)
  week               RouteCycleWeek      @relation(fields: [week_id], references: [id], onDelete: Cascade)
  clientSnapshot     RouteClientSnapshot @relation(fields: [client_snapshot_id], references: [id], onDelete: Cascade)

  @@map("route_assignments")
}

model RouteSequence {
  id                     Int                  @id @default(autoincrement())
  route_cycle_id         Int
  week_id                Int
  supervisor_user_id     Int
  route_date             DateTime?
  start_lat              Float?
  start_lng              Float?
  start_label            String?
  end_lat                Float?
  end_lng                Float?
  end_label              String?
  total_distance_km      Float?
  total_duration_minutes Int?
  average_km_per_visit   Float?
  total_visits           Int?
  optimization_provider  String?              @default("HERE")
  optimization_status    String?              @default("pending")
  raw_response_json      Json?
  created_at             DateTime             @default(now())

  cycle                  RouteCycle           @relation(fields: [route_cycle_id], references: [id], onDelete: Cascade)
  week                   RouteCycleWeek       @relation(fields: [week_id], references: [id], onDelete: Cascade)
  supervisor             User                 @relation(fields: [supervisor_user_id], references: [id])
  items                  RouteSequenceItem[]
  executionLogs          RouteExecutionLog[]

  @@map("route_sequences")
}

model RouteSequenceItem {
  id                             Int                 @id @default(autoincrement())
  route_sequence_id              Int
  sequence_number                Int
  client_snapshot_id             Int
  client_id                      Int
  city                           String?
  state                          String?
  classification                 String?
  stop_lat                       Float?
  stop_lng                       Float?
  distance_from_previous_km      Float?
  duration_from_previous_minutes Int?
  logistic_note                  String?
  is_week_start                  Boolean             @default(false)
  manually_changed               Boolean             @default(false)
  status                         String              @default("pendente") // pendente, agendada, em_rota, visitada, nao_visitada, remarcada, sem_sucesso, venda_feita

  sequence                       RouteSequence       @relation(fields: [route_sequence_id], references: [id], onDelete: Cascade)
  clientSnapshot                 RouteClientSnapshot @relation(fields: [client_snapshot_id], references: [id])
  checkins                       VisitCheckin[]
  results                        VisitResult[]

  @@map("route_sequence_items")
}

model RouteCluster {
  id                  Int            @id @default(autoincrement())
  route_cycle_id      Int
  supervisor_user_id  Int
  week_id             Int
  state               String?
  city                String?
  cluster_name        String?
  classification      String?
  total_clients       Int?
  average_distance_km Float?

  cycle               RouteCycle     @relation(fields: [route_cycle_id], references: [id], onDelete: Cascade)
  week                RouteCycleWeek @relation(fields: [week_id], references: [id], onDelete: Cascade)

  @@map("route_clusters")
}

model RouteBlock {
  id                 Int            @id @default(autoincrement())
  route_cycle_id     Int
  supervisor_user_id Int
  week_id            Int
  block_name         String?
  block_type         String?
  state              String?
  city               String?
  total_clients      Int?
  notes              String?

  cycle              RouteCycle     @relation(fields: [route_cycle_id], references: [id], onDelete: Cascade)
  week               RouteCycleWeek @relation(fields: [week_id], references: [id], onDelete: Cascade)

  @@map("route_blocks")
}

model RouteExecutionLog {
  id                Int           @id @default(autoincrement())
  route_sequence_id Int
  action            String
  action_by         Int
  payload_json      Json?
  created_at        DateTime      @default(now())

  sequence          RouteSequence @relation(fields: [route_sequence_id], references: [id], onDelete: Cascade)

  @@map("route_execution_logs")
}

model VisitCheckin {
  id                     Int               @id @default(autoincrement())
  route_sequence_item_id Int
  checkin_at             DateTime
  checkin_lat            Float?
  checkin_lng            Float?
  checkout_at            DateTime?
  checkout_lat           Float?
  checkout_lng           Float?
  checkin_source         String?
  notes                  String?

  sequenceItem           RouteSequenceItem @relation(fields: [route_sequence_item_id], references: [id], onDelete: Cascade)

  @@map("visit_checkins")
}

model VisitResult {
  id                     Int               @id @default(autoincrement())
  route_sequence_item_id Int
  result_status          String
  sale_made              Boolean           @default(false)
  sale_value             Float?
  notes                  String?
  registered_by          Int
  registered_at          DateTime          @default(now())

  sequenceItem           RouteSequenceItem @relation(fields: [route_sequence_item_id], references: [id], onDelete: Cascade)

  @@map("visit_results")
}

model RouteAuditLog {
  id          Int      @id @default(autoincrement())
  entity_name String
  entity_id   Int
  action      String
  old_data    Json?
  new_data    Json?
  changed_by  Int
  changed_at  DateTime @default(now())
  
  user        User     @relation(fields: [changed_by], references: [id])

  @@map("route_audit_logs")
}

model RouteExport {
  id             Int        @id @default(autoincrement())
  route_cycle_id Int
  export_type    String     // excel, pdf
  export_scope   String     // base_clientes, resumo_supervisores, roteiro_sequencial, resumo_roteiro, clusters, blocos, agenda, densidade
  filters_json   Json?
  generated_by   Int
  generated_at   DateTime   @default(now())
  file_url       String?
  file_name      String?

  cycle          RouteCycle @relation(fields: [route_cycle_id], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [generated_by], references: [id])

  @@map("route_exports")
}

model Group {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("groups")
}

model Module {
  id          String           @id
  name        String
  permissions UserPermission[]

  @@map("modules")
}

model UserPermission {
  userId   Int
  moduleId String
  canView  Boolean @default(false)
  canEdit  Boolean @default(false)
  module   Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@map("user_permissions")
}

model Territory {
  id        Int     @id @default(autoincrement())
  municipio String?
  uf        String?
  modo      String?
  userId    Int?
  user      User?   @relation("UserTerritories", fields: [userId], references: [id])

  @@map("territories")
}

model Bairro {
  id        Int     @id @default(autoincrement())
  bairro    String?
  regiao    String?
  municipio String?
  uf        String?
  modo      String?
  userId    Int?
  user      User?   @relation("UserBairros", fields: [userId], references: [id])

  @@map("bairros")
}

model InterestRequest {
  id          Int      @id @default(autoincrement())
  nome        String
  email       String?
  telefone    String?
  empresa     String?
  municipio   String
  uf          String
  modo        String?
  observacoes String?
  status      String   @default("pending")
  created_at  DateTime @default(now())
  userId      Int?
  user        User?    @relation("UserInterests", fields: [userId], references: [id])

  @@map("interest_requests")
}

model UserActivity {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activities")
}

model Cliente {
  id_cliente        Int                   @id @default(autoincrement())
  codigo_cliente    String?               @unique
  nome_cliente      String
  nome_abreviado    String?
  regiao            String?
  uf                String?
  cidade            String?
  bairro            String?
  cep               String?
  endereco_completo String?
  cnpj              String?
  latitude          Float?
  longitude         Float?
  status_ativo      Boolean               @default(true)
  data_cadastro     DateTime              @default(now())
  data_atualizacao  DateTime              @updatedAt
  semana            String?
  prioridade        String?
  numero            String?
  userId            Int?
  user              User?                 @relation("UserClientes", fields: [userId], references: [id])
  distancias        DistanciasLogistica[]
  historicos        HistoricoVisitas[]
  planejamentos     PlanejamentoVisitas[]

  @@index([userId])
  @@map("clientes")
}

model PlanejamentoVisitas {
  id_visita            Int       @id @default(autoincrement())
  id_cliente           Int
  id_supervisor        Int
  semana               String?
  data_visita_prevista DateTime?
  prioridade           String?
  status               String?   @default("Planejado")
  observacoes          String?
  cliente              Cliente   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  supervisor           User      @relation(fields: [id_supervisor], references: [id], onDelete: Cascade)

  @@map("planejamento_visitas")
}

model DistanciasLogistica {
  id_distancia         Int      @id @default(autoincrement())
  id_cliente           Int
  id_supervisor        Int
  distancia_km         Float?
  modo_transporte      String?
  tempo_estimado_horas Float?
  data_calculo         DateTime @default(now())
  cliente              Cliente  @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  supervisor           User     @relation(fields: [id_supervisor], references: [id], onDelete: Cascade)

  @@map("distancias_logistica")
}

model BlocosViagem {
  id_bloco       Int       @id @default(autoincrement())
  codigo_bloco   String?   @unique
  id_supervisor  Int
  uf             String?
  semana         String?
  total_clientes Int?
  estrategicos   Int?
  km_estimado    Float?
  prioridade     String?
  data_criacao   DateTime?
  supervisor     User      @relation(fields: [id_supervisor], references: [id], onDelete: Cascade)

  @@map("blocos_viagem")
}

model ClustersCidades {
  id_cluster           Int      @id @default(autoincrement())
  uf                   String?
  cidade               String?
  tipo_cluster         String?
  total_clientes       Int?
  densidade            Float?
  supervisor_principal String?
  latitude             Float?
  longitude            Float?
  data_analise         DateTime @default(now())

  @@map("clusters_cidades")
}

model HistoricoVisitas {
  id_historico    Int       @id @default(autoincrement())
  id_cliente      Int
  id_supervisor   Int
  data_visita     DateTime?
  resultado       String?
  valor_negocio   Float?
  proximo_contato DateTime?
  observacoes     String?
  cliente         Cliente   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  supervisor      User      @relation(fields: [id_supervisor], references: [id], onDelete: Cascade)

  @@map("historico_visitas")
}

model ConfigSistema {
  id_config        Int      @id @default(autoincrement())
  parametro        String   @unique
  valor            String?
  descricao        String?
  data_atualizacao DateTime @updatedAt

  @@map("config_sistema")
}

model FeedPost {
  id        Int            @id @default(autoincrement())
  userId    Int
  content   String
  image     String?
  sticker   String?
  createdAt DateTime       @default(now())
  comments  FeedComment[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions FeedReaction[]

  @@map("feed_posts")
}

model FeedComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String
  sticker   String?
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feed_comments")
}

model FeedReaction {
  id     Int      @id @default(autoincrement())
  postId Int
  userId Int
  emoji  String
  post   FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@map("feed_reactions")
}

model Notification {
  id            Int      @id @default(autoincrement())
  title         String
  message       String
  createdAt     DateTime @default(now())
  targetAll     Boolean  @default(true)
  targetUserIds Json?
  senderName    String?  @default("Sistema")

  @@map("notifications")
}

model UserType {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  color           String   @default("#3b82f6")
  showInMenu      Boolean  @default(false)
  createdAt       DateTime @default(now())
  active          Boolean  @default(true)
  isSystemDefault Boolean  @default(false)
  updatedAt       DateTime @default(now()) @updatedAt
  isAdmin         Boolean  @default(false)
  icon            String   @default("User")
  users           User[]

  @@map("user_types")
}
