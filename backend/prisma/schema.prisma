generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  supabase_id   String?  @unique
  username      String   @unique
  password     String
  role         String    @default("user") // admin, supervisor, user
  tipo         String    @default("Usuário")
  userTypeId    Int?
  userType      UserType? @relation(fields: [userTypeId], references: [id])
  full_name    String?
  cpf_cnpj     String?
  telefone     String?
  cargo        String?
  company_name String?
  email        String?
  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro_end   String?
  cidade       String?
  estado_end   String?
  photo        String?
  area_atuacao String?
  base_logistica String?
  code         String?   @unique
  birth_date   DateTime?
  groupId      Int?
  group        Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  colorIndex   Int       @default(0)
  comissao     Float?
  isVago       Int       @default(0)
  created_at   DateTime  @default(now())

  // Configurações e Notificações
  default_workspace String?  @default("admin")
  inactivity_limit  Int?     @default(30) // minutos
  notif_email       Boolean  @default(true)
  notif_sms         Boolean  @default(false)
  notif_push        Boolean  @default(true)
  last_active       DateTime @default(now())
  token_version     Int      @default(0)

  // Relations
  permissions       UserPermission[]
  visitasLogistica  DistanciasLogistica[]
  planejamentos     PlanejamentoVisitas[]
  blocosViagem      BlocosViagem[]
  historicosVisitas HistoricoVisitas[]
  activities        UserActivity[]

  // Novas relações diretas
  territories  Territory[] @relation("UserTerritories")
  bairros      Bairro[]    @relation("UserBairros")
  clientes     Cliente[]   @relation("UserClientes")
  interests    InterestRequest[] @relation("UserInterests")

  FeedPost     FeedPost[]
  FeedComment  FeedComment[]
  FeedReaction FeedReaction[]

  @@map("users")
}

model Group {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("groups")
}

model Module {
  id          String           @id
  name        String
  permissions UserPermission[]

  @@map("modules")
}

model UserPermission {
  userId   Int
  moduleId String
  canView  Boolean @default(false)
  canEdit  Boolean @default(false)
  module   Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@map("user_permissions")
}

model Territory {
  id        Int     @id @default(autoincrement())
  municipio String?
  uf        String?
  modo      String?
  userId    Int?
  user      User?   @relation("UserTerritories", fields: [userId], references: [id], onDelete: SetNull)

  @@map("territories")
}

model Bairro {
  id        Int     @id @default(autoincrement())
  bairro    String?
  regiao    String?
  municipio String?
  uf        String?
  modo      String?
  userId    Int?
  user      User?   @relation("UserBairros", fields: [userId], references: [id], onDelete: SetNull)

  @@map("bairros")
}

model InterestRequest {
  id          Int      @id @default(autoincrement())
  nome        String
  email       String?
  telefone    String?
  empresa     String?
  municipio   String
  uf          String
  modo        String?
  observacoes String?
  status      String   @default("pending")
  userId      Int?
  user        User?    @relation("UserInterests", fields: [userId], references: [id], onDelete: SetNull)
  created_at  DateTime @default(now())

  @@map("interest_requests")
}

model UserActivity {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activities")
}

model Cliente {
  id_cliente        Int                    @id @default(autoincrement())
  codigo_cliente    String?                @unique
  nome_cliente      String
  nome_abreviado    String?
  regiao            String?
  uf                String?
  cidade            String?
  bairro            String?
  cep               String?
  endereco_completo String?
  numero            String?
  cnpj              String?
  latitude          Float?
  longitude         Float?
  status_ativo      Boolean                @default(true)
  data_cadastro     DateTime               @default(now())
  data_atualizacao  DateTime               @updatedAt
  semana            String?
  prioridade        String?
  userId            Int?
  user              User?                  @relation("UserClientes", fields: [userId], references: [id], onDelete: SetNull)
  distancias        DistanciasLogistica[]
  historicos        HistoricoVisitas[]
  planejamentos     PlanejamentoVisitas[]

  @@map("clientes")
}

model PlanejamentoVisitas {
  id_visita            Int       @id @default(autoincrement())
  id_cliente           Int
  id_supervisor        Int
  semana               String?
  data_visita_prevista DateTime?
  prioridade           String?
  status               String?   @default("Planejado")
  observacoes          String?
  cliente              Cliente   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  supervisor           User      @relation(fields: [id_supervisor], references: [id], onDelete: Cascade)

  @@map("planejamento_visitas")
}

model DistanciasLogistica {
  id_distancia         Int      @id @default(autoincrement())
  id_cliente           Int
  id_supervisor        Int
  distancia_km         Float?
  modo_transporte      String?
  tempo_estimado_horas Float?
  data_calculo         DateTime @default(now())
  cliente              Cliente  @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  supervisor           User     @relation(fields: [id_supervisor], references: [id], onDelete: Cascade)

  @@map("distancias_logistica")
}

model BlocosViagem {
  id_bloco       Int       @id @default(autoincrement())
  codigo_bloco   String?   @unique
  id_supervisor  Int
  uf             String?
  semana         String?
  total_clientes Int?
  estrategicos   Int?
  km_estimado    Float?
  prioridade     String?
  data_criacao   DateTime?
  supervisor     User      @relation(fields: [id_supervisor], references: [id], onDelete: Cascade)

  @@map("blocos_viagem")
}

model ClustersCidades {
  id_cluster           Int      @id @default(autoincrement())
  uf                   String?
  cidade               String?
  tipo_cluster         String?
  total_clientes       Int?
  densidade            Float?
  supervisor_principal String?
  latitude             Float?
  longitude            Float?
  data_analise         DateTime @default(now())

  @@map("clusters_cidades")
}

model HistoricoVisitas {
  id_historico    Int       @id @default(autoincrement())
  id_cliente      Int
  id_supervisor   Int
  data_visita     DateTime?
  resultado       String?
  valor_negocio   Float?
  proximo_contato DateTime?
  observacoes     String?
  cliente         Cliente   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  supervisor      User      @relation(fields: [id_supervisor], references: [id], onDelete: Cascade)

  @@map("historico_visitas")
}

model ConfigSistema {
  id_config        Int      @id @default(autoincrement())
  parametro        String   @unique
  valor            String?
  descricao        String?
  data_atualizacao DateTime @updatedAt

  @@map("config_sistema")
}

model FeedPost {
  id        Int            @id @default(autoincrement())
  userId    Int
  content   String
  image     String?
  sticker   String? // URL of the sticker if provided
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  FeedComment[]
  reactions FeedReaction[]

  @@map("feed_posts")
}

model FeedComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String
  sticker   String?
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feed_comments")
}

model FeedReaction {
  id     Int      @id @default(autoincrement())
  postId Int
  userId Int
  emoji  String
  post   FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@map("feed_reactions")
}

model Notification {
  id            Int      @id @default(autoincrement())
  title         String
  message       String   @db.Text
  targetAll     Boolean  @default(true)
  targetUserIds Json?
  senderName    String?  @default("Sistema")
  createdAt     DateTime @default(now())

  @@map(name: "notifications")
}

model UserType {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  color           String   @default("#3b82f6")
  icon            String   @default("User")
  showInMenu      Boolean  @default(false)
  active          Boolean  @default(true)
  isAdmin         Boolean  @default(false)
  isSystemDefault Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  users           User[]

  @@map(name: "user_types")
}
